# Krumos PM Backend Environment Variables
# Copy this file to .env and adjust the settings.

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (Neon DB Serverless or Local Postgres)
DATABASE_URL=neon_db_database_url

# CORS Policy configuration
FRONTEND_URL=http://localhost:5173

# Authentication Secrets
JWT_SECRET=krumos-default-secret
JWT_EXPIRY=24h

# Google OAuth credentials (for login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Email Notification credentials (via Brevo)
BREVO_API_KEY=your_brevo_api_key
BREVO_FROM_EMAIL=your-email@example.com
BREVO_FROM_NAME=Krumos

# Redis connection
REDIS_URL=redis://localhost:6379

# Soft delete retention period (in days)
SOFT_DELETE_RETENTION_DAYS=
